<header class="header js-nav-dropdown-container">
  <div class="header__top">
    <div class="container header__top-inner">
      <button
        class="header__city-select city-select focus js-city-select-toggle"
        type="button"
        aria-expanded="false"
        aria-controls="city-panel"
      >
        {% set icon ={
            name: "location",
            class: "city-select__icon"
          }
        %}
        {% include "partials/icon/icon.njk" %}
        <span class="city-select__text">Черемхово</span>
      </button>

      <a class="header__support-link focus" href="{{ notFoundPageUrl }}">Техподдержка</a>
      <a class="header__phone focus" href="tel:+78004441109">+7 800 444 11 09</a>
    </div>

    {% include "partials/city-panel/city-panel.njk" %}
  </div>

  <div class="container header__bottom">
    <a class="header__logo focus" href="/">
      <picture>
        <source srcset="/src/assets/images/logo-2x.png 2x, /src/assets/images/logo-1x.png 1x">
        <img
          class="header__logo-img"
          src="/src/assets/images/logo-1x.png"
          width="226"
          height="45"
          alt="Большие Связи"
        />
      </picture>
    </a>

    <nav class="header__nav" aria-label="Основная навигация">
      {% from "macros/nav-dropdown/nav-dropdown.njk" import navDropdown %}

      {{ navDropdown("about", "О компании", [
        { text: "Деятельность", href: "/pages/activity.html" },
        { text: "Вакансии", href: "/pages/vacancies.html" },
        { text: "Инструкции", href: "/pages/instructions.html" },
        { text: "Новости", href: "/pages/news.html" },
        { text: "Контакты", href: "/pages/contacts.html" }
      ]) }}

      {{ navDropdown("tariffs", "Тарифы и услуги", [
        "Интернет в много-квартирный дом",
        { text: "Интернет для частного сектора", href: "/pages/private-internet.html" },
        "Домофония",
        { text: "Видеонаблюдение", href: "/pages/home-video-surveillance.html" },
        { text: "Радио", href: notFoundPageUrl },
        { text: "Телевидение", href: "/pages/television.html" },
        "Рассрочка"
      ]) }}
    </nav>

    <div class="header__actions">
      {% set button ={
          text: "Пополнить баланс",
          href: notFoundPageUrl,
          variant: "blue",
          class: "btn--198"
        }
      %}
      {% include "partials/button/button.njk" %}

      {% set button ={
          text: "Подключиться",
          type: "button",
          variant: "orange",
          class: "btn--198",
          dataBcOpen: "callback-modal"
        }
      %}
      {% include "partials/button/button.njk" %}

      <a class="profile-btn focus" href="{{ notFoundPageUrl }}" aria-label="Профиль">
        {% set icon ={
            name: "profile",
            class: "profile-btn__icon"
          }
        %}
        {% include "partials/icon/icon.njk" %}
      </a>
    </div>
  </div>
</header>
