<div class="modal modal--slide" id="{{ modal.id }}" aria-hidden="true">
  <div class="modal__overlay" tabindex="-1" data-bc-close="{{ modal.id }}">
    <div class="modal__container" role="dialog" aria-modal="true" aria-labelledby="{{ modal.id }}-title">
      {% block content %}
      {% endblock %}

      {% set closeClass = "modal__close" %}
      {% set closeIconClass = "modal__close-icon" %}
      {% set dataBcClose = modal.id %}
      {% include "partials/close/close.njk" %}
    </div>
  </div>
</div>