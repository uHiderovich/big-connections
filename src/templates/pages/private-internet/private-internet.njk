{% from "macros/breadcrumbs/breadcrumbs.njk" import breadcrumbs %}

<section class="tariff-page">
  <div class="container">
    {{ breadcrumbs([
      { text: "Тарифы и услуги" },
      { text: "Интернет для частного сектора" }
    ]) }}

    <h1 class="section-title tariff-page__title">
      Тарифы для частного сектора / г. Черемхово
    </h1>

    <ul class="tariff-page__grid">
      {% for item in privateInternetTariffs %}
        {% set tariff = item %}
        {% include "partials/tariff-card/tariff-card.njk" %}
      {% endfor %}
    </ul>
  </div>
</section>
